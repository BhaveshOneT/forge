{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forge State",
  "type": "object",
  "required": [
    "session_id",
    "current_phase",
    "tier",
    "phase_attempt",
    "total_backtracks",
    "build_review_loop"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "pattern": "^forge-[A-Za-z0-9._-]+$"
    },
    "current_phase": {
      "type": "string",
      "enum": [
        "classify",
        "grill",
        "jira_fetch",
        "confluence_enrich",
        "synthesize",
        "explore",
        "architect",
        "build",
        "review",
        "verify",
        "ship",
        "compound",
        "complete"
      ]
    },
    "tier": {
      "type": "integer",
      "enum": [1, 2, 3]
    },
    "phase_attempt": {
      "type": "integer",
      "minimum": 1
    },
    "total_backtracks": {
      "type": "integer",
      "minimum": 0
    },
    "build_review_loop": {
      "type": "integer",
      "minimum": 0
    },
    "studio_enabled": {
      "type": "boolean"
    },
    "studio_session_name": {
      "type": "string",
      "pattern": "^forge-forge-[A-Za-z0-9._-]+$"
    },
    "studio_layout_mode": {
      "type": "string",
      "enum": ["focus", "build", "swarm"]
    },
    "studio_status": {
      "type": "string",
      "enum": ["starting", "active", "paused", "complete"]
    },
    "studio_panes": {
      "type": "object",
      "required": ["main", "git", "status"],
      "additionalProperties": false,
      "properties": {
        "main": { "type": "string", "minLength": 1 },
        "git": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 }
      }
    },
    "studio_created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+Z$"
    },
    "studio_persistent": {
      "type": "boolean"
    },
    "studio_last_focus": {
      "type": "string",
      "enum": ["main", "git", "status", "popup"]
    },
    "studio_workspace_ready": {
      "type": "boolean"
    },
    "complexity_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 16
    },
    "project_type": {
      "type": "string",
      "enum": ["greenfield", "brownfield"]
    },
    "checkpoint": {
      "type": "string"
    },
    "user_request": {
      "type": "string"
    },
    "tokens_estimate": {
      "type": "integer",
      "minimum": 0
    },
    "execution_mode": {
      "type": "string",
      "enum": ["prompt", "jira"]
    },
    "source": {
      "type": "string",
      "enum": ["", "jira"]
    },
    "jira_issue_key": {
      "type": "string"
    },
    "jira_issue_type": {
      "type": "string"
    },
    "jira_priority": {
      "type": "string"
    },
    "project_dir": {
      "type": "string"
    },
    "worktree_path": {
      "type": "string"
    },
    "worktree_branch": {
      "type": "string"
    },
    "worktree_created": {
      "type": "boolean"
    },
    "worktree_cleaned": {
      "type": "boolean"
    },
    "grilling_override": {
      "type": "string",
      "enum": ["minimal", "standard", "confirm_scope"]
    },
    "phase_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "status"],
        "properties": {
          "phase": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "complete", "failed"]
          },
          "confidence": {
            "type": ["number", "integer"],
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "active_agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["subagent", "team"]
          },
          "status": {
            "type": "string"
          },
          "task": {
            "type": "string"
          },
          "log_file": {
            "type": "string"
          },
          "started_at": {
            "type": "string"
          },
          "finished_at": {
            "type": "string"
          }
        }
      }
    },
    "build_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      }
    },
    "ship_result": {
      "type": "object"
    }
  }
}
