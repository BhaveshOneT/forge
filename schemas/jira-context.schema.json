{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forge Jira Context",
  "type": "object",
  "required": [
    "issue_key",
    "summary",
    "description",
    "issue_type"
  ],
  "properties": {
    "issue_key": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "issue_type": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "assignee": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "string"
    },
    "linked_pages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "subtasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "summary"],
        "properties": {
          "key": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}
